{
  "mcpServers": {
    "linkedin": {
      "command": "uvx",
      "args": ["linkedin-scraper-mcp@latest"],
      "env": { "UV_HTTP_TIMEOUT": "300" }
    },
    "jobspy": {
      "command": "node",
      "args": ["vendor/jobspy-mcp-server/src/index.js"],
      "env": { "ENABLE_SSE": "0", "JOBSPY_DOCKER_IMAGE": "jobspy" }
    }
  }
}
